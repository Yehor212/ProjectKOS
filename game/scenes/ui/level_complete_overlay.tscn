[gd_scene load_steps=3 format=3 uid="uid://cslevel_complete"]

[ext_resource type="Script" path="res://scripts/minigames/level_complete_overlay.gd" id="1_script"]
[ext_resource type="Script" path="res://scripts/components/ui_popper.gd" id="2_popper"]

[node name="LevelCompleteOverlay" type="CanvasLayer"]
layer = 50
script = ExtResource("1_script")

[node name="Backdrop" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.5)
mouse_filter = 1

[node name="CenterPanel" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -200.0
offset_right = 160.0
offset_bottom = 200.0
size_flags_horizontal = 4
grow_horizontal = 2
grow_vertical = 2

[node name="UIPopper" type="Node" parent="CenterPanel"]
script = ExtResource("2_popper")

[node name="VBox" type="VBoxContainer" parent="CenterPanel"]
layout_mode = 2
theme_override_constants/separation = 24
alignment = 1

[node name="BigStar" type="Control" parent="CenterPanel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(96, 96)
size_flags_horizontal = 4

[node name="TitleLabel" type="Label" parent="CenterPanel/VBox"]
layout_mode = 2
theme_type_variation = &"TitleLabel"
theme_override_colors/font_color = Color(1, 0.82, 0.4, 1)
theme_override_font_sizes/font_size = 44
text = "Level Complete!"
horizontal_alignment = 1

[node name="StarCountBox" type="HBoxContainer" parent="CenterPanel/VBox"]
layout_mode = 2
theme_override_constants/separation = 8
alignment = 1

[node name="StarCountLabel" type="Label" parent="CenterPanel/VBox/StarCountBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "+0"
horizontal_alignment = 1

[node name="StarCountIcon" type="Control" parent="CenterPanel/VBox/StarCountBox"]
layout_mode = 2
custom_minimum_size = Vector2(36, 36)

[node name="ContinueButton" type="Button" parent="CenterPanel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(300, 80)
theme_type_variation = &"AccentButton"
text = "Continue"

[connection signal="pressed" from="CenterPanel/VBox/ContinueButton" to="." method="_on_continue_pressed"]
