[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/parental_gate.gd" id="1_script"]

[node name="ParentalGate" type="CanvasLayer"]
process_mode = 3
visible = false
script = ExtResource("1_script")

[node name="Overlay" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 1
color = Color(0, 0, 0, 0.6)

[node name="PanelContainer" type="PanelContainer" parent="Overlay"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -280.0
offset_top = -220.0
offset_right = 280.0
offset_bottom = 220.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="Overlay/PanelContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="InstructionLabel" type="Label" parent="Overlay/PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Enter the numbers shown as words"
horizontal_alignment = 1
autowrap_mode = 2

[node name="PromptLabel" type="Label" parent="Overlay/PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Tap: Two, Eight, Four"
horizontal_alignment = 1

[node name="DigitsHBox" type="HBoxContainer" parent="Overlay/PanelContainer/VBoxContainer"]
layout_mode = 2
alignment = 1

[node name="DigitsLabel" type="Label" parent="Overlay/PanelContainer/VBoxContainer/DigitsHBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "_  _  _"
horizontal_alignment = 1

[node name="KeypadGrid" type="GridContainer" parent="Overlay/PanelContainer/VBoxContainer"]
layout_mode = 2
columns = 5
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="Btn1" type="Button" parent="Overlay/PanelContainer/VBoxContainer/KeypadGrid"]
layout_mode = 2
custom_minimum_size = Vector2(80, 80)
theme_type_variation = &"CircleButton"
text = "1"

[node name="Btn2" type="Button" parent="Overlay/PanelContainer/VBoxContainer/KeypadGrid"]
layout_mode = 2
