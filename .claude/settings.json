{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/commit-gate.cjs",
            "timeout": 120000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/advisory-warnings.cjs",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/advisory-warnings.cjs",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/fullcycle-flag.cjs",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/preflight-inject.cjs",
            "timeout": 5000,
            "statusMessage": "Pre-flight check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-stop-gate.cjs",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
