# Godot 4+ specific ignores
.godot/

# Godot-specific ignores
*.translation
export_presets.cfg

# Imported resources (auto-generated by Godot)
*.import
*.uid

# Temp/backup files
*.tmp
*.dscn

# OS-specific
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code MCP config (may contain tokens)
.mcp.json

# Build artifacts & signing keys
.keys/
build/
*.keystore
*.aab
*.apk

# Claude Code enforcement tokens (one-time, auto-deleted)
.postflight-done
.fullcycle-active
.fullcycle-laws-read

# Asset downloads (large binaries, not shipped)
.asset_downloads/

# Secrets / env
.env
*.secret
credentials.json

# Auto-generated hook tokens (not tracked)
.preflight-token
.user-requirements

# RuFlo V3 — tooling infrastructure (not project code)
.claude-flow/
.claude/agents/
.claude/commands/
.claude/helpers/
.claude/skills/

# Auto-generated gate tokens
.postflight-done
.fullcycle-active
.fullcycle-laws-read
